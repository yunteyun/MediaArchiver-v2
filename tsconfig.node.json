{
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "lib": [
            "ES2023",
            "DOM"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",
        "types": [
            "node",
            "vite/client"
        ],
        "strict": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "vite.config.ts",
        "electron",
        "src/components/Toast.tsx",
        "src/components/fileCard/**/*.ts",
        "src/components/lightbox/shared/**/*.ts",
        "src/shared/**/*.ts",
        "src/stores/**/*.ts",
        "src/types/**/*.ts",
        "src/utils/fileListQuery.ts",
        "src/utils/perfDebug.ts"
    ],
    "exclude": [
        "**/__tests__/**"
    ]
}
